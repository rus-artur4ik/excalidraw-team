# Copy to `stack.env` and fill in. Used by docker-compose.stack.yml:
#   docker compose --env-file stack.env -f docker-compose.stack.yml up --build -d
# `stack.env` is git-ignored.

# ---- Public URLs the BROWSER uses (baked into the frontend build) ----
# Everything goes through the proxy, so all three are the SAME origin.
# Local: the proxy port below. Prod (behind Cloudflare): https://excalidraw.artavian.com
PUBLIC_APP_ORIGIN=http://localhost:18080
PUBLIC_WS_URL=http://localhost:18080
PUBLIC_BACKEND_URL=http://localhost:18080

# ---- Reverse-proxy port (the ONLY published port; Cloudflare/cloudflared sends HTTP here) ----
# Non-standard on purpose. With a Cloudflare Tunnel any port works.
PROXY_PORT=18080

# ---- Firebase ----
FIREBASE_PROJECT_ID=excalidraw-team
# Web SDK config as a SINGLE-LINE JSON string, no spaces (apiKey is not a secret).
VITE_APP_FIREBASE_CONFIG={"apiKey":"AIzaSyAfv4cyDog8ZD44exVDoOrsVM3sNZGb4Xg","authDomain":"excalidraw-team.firebaseapp.com","projectId":"excalidraw-team","storageBucket":"excalidraw-team.firebasestorage.app","messagingSenderId":"977923226845","appId":"1:977923226845:web:319986278df00a54f5ef34"}
# Web API key (same apiKey as above). Backend exchanges the bot's custom token for an ID token.
FIREBASE_WEB_API_KEY=AIzaSyAfv4cyDog8ZD44exVDoOrsVM3sNZGb4Xg

# ---- Shared secret for room <-> backend internal calls ----
INTERNAL_SECRET=change-me-to-a-long-random-string
